# Postgres connection string.
# Local dev: the docker postgres (postgresql://postgres:password@127.0.0.1:5432/balance_point)
# Vercel: the Neon *pooled* connection string (host contains "-pooler", ends with ?sslmode=require)
DATABASE_URL=

# Random secret with 32+ chars (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Public URL the app is served from.
# Local dev: http://localhost:3001 — Vercel: https://<project>.vercel.app
BETTER_AUTH_URL=
